# Server config
PORT=3001
DATABASE_PATH=./data/cockpit.db

# Optional — only needed if you don't want to use your Claude Code subscription auth
# ANTHROPIC_API_KEY=

# Jira / Atlassian — get token at id.atlassian.com/manage-profile/security/api-tokens
JIRA_SITE=maxxton.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
# Use `bearer` for "API token with scopes", `basic` for classic API tokens
JIRA_AUTH_TYPE=basic

# Folder containing your local git repos — used to detect uncommitted/unpushed work per ticket
# Defaults to %USERPROFILE%\IdeaProjects (Windows) if unset
# LOCAL_REPOS_ROOT=C:\Users\d.ghumed\IdeaProjects

# Working directory the full-access "Claude" agent operates from.
# Affects which project's .claude/ settings (MCPs, slash commands) load.
# Defaults to your home dir.
# AGENT_CWD=C:\Users\d.ghumed\IdeaProjects\third-party-v2-service
